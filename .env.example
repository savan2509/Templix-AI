# -----------------------------------------------------------------------------
# Templix AI Environment Configuration Template
# -----------------------------------------------------------------------------

# 1. Database (PostgreSQL / Neon serverless)
DATABASE_URL="postgresql://username:password@ep-cool-name.us-east-2.aws.neon.tech/templix?sslmode=require"

# 2. Authentication (Auth.js / NextAuth.js v5)
# Generate a secure secret using: npx auth secret or openssl rand -base64 32
AUTH_SECRET="your_nextauth_secret_here"

# Auth.js App URL (automatically detected on Vercel, required on local/other hosts)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 3. OAuth Credentials (Optional for email magic links, required for buttons)
# Google Developer Console: https://console.cloud.google.com
AUTH_GOOGLE_ID="google_oauth_client_id"
AUTH_GOOGLE_SECRET="google_oauth_client_secret"

# GitHub Settings Developer Settings: https://github.com/settings/developers
AUTH_GITHUB_ID="github_oauth_client_id"
AUTH_GITHUB_SECRET="github_oauth_client_secret"

# 4. Email Service (SMTP — used to send magic sign-in links)
# These are the variables the app actually reads (see src/auth.ts).
# Recommended: Resend SMTP (https://resend.com) — reliable on serverless/Vercel.
#   Host: smtp.resend.com  User: resend  Password: your Resend API key (re_...)
# Gmail also works: host smtp.gmail.com, user your@gmail.com, password = a
#   Gmail App Password (requires 2-Step Verification enabled).
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="resend"
EMAIL_SERVER_PASSWORD="re_your_resend_api_key"
EMAIL_FROM="onboarding@resend.dev"

# 5. Media Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# 6. AI Workspace Service Keys
# Google AI Studio: https://aistudio.google.com
GEMINI_API_KEY="AIzaSyYourGeminiApiKeyHere"

# 7. System Monitoring & Log Levels
LOG_LEVEL="info" # info | debug | warn | error
SENTRY_DSN=""
